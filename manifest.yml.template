---
applications:
  - name: banking-sentinel
    memory: 1G
    disk_quota: 1G
    instances: 1
    buildpacks:
      - nodejs_buildpack
    command: npm start
    routes:
      - route: banking-sentinel.cfapps.us10-001.hana.ondemand.com
    services:
      - banking-sentinel-db
    env:
      NODE_ENV: production
      # Credentials: never in this file — set once via cf set-env after first deploy:
      #   cf set-env banking-sentinel ANTHROPIC_API_KEY xxx
      #   cf set-env banking-sentinel OPENAI_API_KEY xxx
      #   cf set-env banking-sentinel LANGFUSE_SECRET_KEY xxx
      #   cf set-env banking-sentinel LANGFUSE_PUBLIC_KEY xxx
      #   cf set-env banking-sentinel POSTGRES_URL xxx
      #   cf set-env banking-sentinel GRAPHDB_USERNAME xxx
      #   cf set-env banking-sentinel GRAPHDB_PASSWORD xxx
      #   cf set-env banking-sentinel SAP_RPT_API_KEY xxx
      #   cf set-env banking-sentinel SOLACE_PASSWORD xxx
      #   cf restage banking-sentinel
      ANTHROPIC_MODEL: claude-haiku-4-5-20251001
      OPENAI_EMBEDDING_MODEL: text-embedding-3-small
      LANGFUSE_HOST: https://us.cloud.langfuse.com
      LANGFUSE_BASE_URL: https://us.cloud.langfuse.com
      GRAPHDB_ENDPOINT: https://t5f027c83a0e2488da5e.sandbox.graphwise.ai
      GRAPHDB_REPOSITORY: banking-sentinel
      ANOMALY_ENGINE: scikit
      SCIKIT_SERVICE_URL: http://localhost:5001
      SOLACE_URL: wss://mr-connection-rcgt0ju559a.messaging.solace.cloud:443
      SOLACE_VPN: mj-live
      SOLACE_USERNAME: solace-cloud-client
      ADMIN_IP_WHITELIST: disabled
