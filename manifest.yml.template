---
applications:
  - name: banking-sentinel
    memory: 1G
    disk_quota: 1G
    instances: 1
    buildpacks:
      - nodejs_buildpack
    command: npm start
    routes:
      - route: banking-sentinel.cfapps.us10-001.hana.ondemand.com
    services:
      - banking-sentinel-db
    env:
      NODE_ENV: production
      # Credentials AND anything that rotates/expires (GraphDB sandbox URL,
      # Solace connection details) — never in this file, set once via
      # cf set-env after first deploy, re-sync whenever they rotate:
      #   cf set-env banking-sentinel ANTHROPIC_API_KEY xxx
      #   cf set-env banking-sentinel OPENAI_API_KEY xxx
      #   cf set-env banking-sentinel LANGFUSE_SECRET_KEY xxx
      #   cf set-env banking-sentinel LANGFUSE_PUBLIC_KEY xxx
      #   cf set-env banking-sentinel POSTGRES_URL xxx
      #   cf set-env banking-sentinel GRAPHDB_USERNAME xxx
      #   cf set-env banking-sentinel GRAPHDB_PASSWORD xxx
      #   cf set-env banking-sentinel GRAPHDB_ENDPOINT xxx
      #   cf set-env banking-sentinel SAP_RPT_API_KEY xxx
      #   cf set-env banking-sentinel SOLACE_PASSWORD xxx
      #   cf set-env banking-sentinel SOLACE_URL xxx
      #   cf set-env banking-sentinel SOLACE_VPN xxx
      #   cf set-env banking-sentinel SOLACE_USERNAME xxx
      #   cf restage banking-sentinel
      ANTHROPIC_MODEL: claude-haiku-4-5-20251001
      OPENAI_EMBEDDING_MODEL: text-embedding-3-small
      LANGFUSE_HOST: https://us.cloud.langfuse.com
      LANGFUSE_BASE_URL: https://us.cloud.langfuse.com
      GRAPHDB_REPOSITORY: banking-sentinel
      ANOMALY_ENGINE: scikit
      SCIKIT_SERVICE_URL: https://banking-sentinel-scikit.cfapps.us10-001.hana.ondemand.com
      ADMIN_IP_WHITELIST: disabled
      LLM_PROVIDER: anthropic
      MCP_ALLOWED_ENTITIES: BusinessPartners,Loans,LoanSchedule,LoanStatusCodes,BCA_DTI,DFKKOP,DFKKOPK,BCA_GUARANTOR,BCA_COLLATERAL,BCA_SECTOR,RiskAssessments

  # ── Scikit Isolation Forest anomaly service (Flask) ──────────────────────────
  # AI: separate CF app so the Node app's nodejs_buildpack doesn't need Python.
  # Banking: ANOMALY_ENGINE=scikit (above) calls this app's /anomaly endpoint.
  - name: banking-sentinel-scikit
    memory: 512M
    disk_quota: 512M
    instances: 1
    buildpacks:
      - python_buildpack
    path: ml
    command: python anomaly-service.py
    routes:
      - route: banking-sentinel-scikit.cfapps.us10-001.hana.ondemand.com
